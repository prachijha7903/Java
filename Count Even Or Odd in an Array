class CountEvenOddInArray{
    public static void main(String[] args){
        int[] arr = { 2, 4 , 6 , 9 , 10};
        int even = 0 , odd = 0 ;

        for(int i = 0 ; i < arr.length ; i ++){
            if(arr[i] % 2 == 0){
                even++;
            }else{
                odd++;
            }
        }
        System.out.println("Total even number of array are : " + even);
        System.out.println("Total odd number of array are : " + odd);
    }
}
